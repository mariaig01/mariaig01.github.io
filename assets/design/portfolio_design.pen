              "name": "Details Section",
              "width": "fill_container",
              "layout": "vertical",
              "gap": 16,
              "children": [
                {
                  "type": "text",
                  "id": "EzYvC",
                  "name": "detailsLabel",
                  "fill": "#FFA6CD",
                  "content": "PROJECT DETAILS / BACKGROUND",
                  "fontFamily": "JetBrains Mono",
                  "fontSize": 12,
                  "fontWeight": "600",
                  "letterSpacing": 2
                },
                {
                  "type": "text",
                  "id": "R9xIQ",
                  "name": "p1",
                  "fill": "#94A3B8",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Designed and developed a real-time augmented reality (AR) system with computer vision and deep learning, leveraging OpenCV, PyTorch, and Keras. The system renders a 3D representation of a Windows PC on any physical surface using visual markers.",
                  "lineHeight": 1.75,
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "OfHru",
                  "name": "p2",
                  "fill": "#94A3B8",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Engineered an AI-powered assistant named \"Alberto\" with NLP capabilities and CNN-based facial recognition for secure authentication. The assistant executes voice commands and interacts with the AR environment.",
                  "lineHeight": 1.75,
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "normal"
                },
                {
                  "type": "text",
                  "id": "JaDSM",
                  "name": "p3",
                  "fill": "#94A3B8",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Innovated a cost-effective AR solution by transforming consumer VR glasses + smartphone into an interactive AR device via server-client real-time streaming with a custom Android APK.",
                  "lineHeight": 1.75,
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "normal"
                }
              ]
            }
          ]
        }
      ]
