              "name": "title",
              "fill": "#FFFFFF",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "Enterprise RAG System",
              "lineHeight": 1.2,
              "fontFamily": "Inter",
              "fontSize": 40,
              "fontWeight": "800"
            },
            {
              "type": "text",
              "id": "O0hcG",
              "name": "tagline",
              "fill": "#94A3B8",
              "textGrowth": "fixed-width",
              "width": "fill_container",
              "content": "A production Retrieval-Augmented Generation system for internal knowledge retrieval and decision support, deployed at enterprise scale with monitoring and continuous optimization.",
              "lineHeight": 1.75,
              "fontFamily": "Inter",
              "fontSize": 16,
              "fontWeight": "normal"
            },
            {
              "type": "frame",
              "id": "dHPJF",
              "name": "Hero Image",
              "width": "fill_container",
              "height": 350,
              "fill": {
