                  "name": "p3",
                  "fill": "#94A3B8",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Innovated a cost-effective AR solution by transforming consumer VR glasses + smartphone into an interactive AR device via server-client real-time streaming with a custom Android APK.",
                  "lineHeight": 1.75,
                  "fontFamily": "Inter",
                  "fontSize": 16,
                  "fontWeight": "normal"
                }
              ]
            }
          ]
        }
      ]
